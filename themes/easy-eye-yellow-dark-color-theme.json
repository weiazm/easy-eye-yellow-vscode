    "terminal.background": "#2B2818",
    "terminal.foreground": "#FFF5C7",
    "terminal.selectionBackground": "#5B5230",
    "terminalCursor.foreground": "#FFF0A6",
    "terminal.ansiBlack": "#202020",
    "terminal.ansiRed": "#FF9A84",
    "terminal.ansiGreen": "#6FCA83",
    "terminal.ansiYellow": "#D8AE68",
    "terminal.ansiBlue": "#9EB0FF",
    "terminal.ansiMagenta": "#D9A4FF",
    "terminal.ansiCyan": "#66D6C9",
    "terminal.ansiWhite": "#FFF5C7",
    "terminal.ansiBrightBlack": "#777777",
    "terminal.ansiBrightRed": "#FFB3A1",
    "terminal.ansiBrightGreen": "#8AD49C",
    "terminal.ansiBrightYellow": "#FFF0A6",
    "terminal.ansiBrightBlue": "#55C6F0",
    "terminal.ansiBrightMagenta": "#E1BBFF",
    "terminal.ansiBrightCyan": "#62BFC0",
    "terminal.ansiBrightWhite": "#FFFFFF"
  },
  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text",
        "variable.other"
      ],
      "settings": {
        "foreground": "#FFF5C7"
      }
    },
    {
      "name": "Line comments",
      "scope": [
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#62BFC0"
      }
    },
    {
      "name": "Block and documentation comments",
      "scope": [
        "comment.block",
        "comment.block.documentation",
        "comment.documentation"
      ],
      "settings": {
        "foreground": "#6FCA83"
      }
    },
    {
      "name": "Documentation comment tags",
      "scope": [
        "storage.type.class.jsdoc",
        "entity.name.type.instance.jsdoc",
        "variable.other.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "keyword.other.documentation"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#8AD49C"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "support.type.primitive"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#9EB0FF"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#FFF5C7"
      }
    },
    {
      "name": "Braces, brackets, and parens",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "punctuation.definition.array",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#D4C88F"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#66D6C9"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp",
        "constant.character.character-class.regexp",
        "constant.character.set.regexp"
      ],
      "settings": {
        "foreground": "#D9A4FF"
      }
    },
    {
      "name": "Invalid and deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#777777"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.character.numeric"
      ],
      "settings": {
        "foreground": "#D9A4FF"
      }
    },
    {
      "name": "Constants and labels",
      "scope": [
        "constant.language",
        "constant.other",
        "entity.name.label",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D8AE68"
      }
    },
    {
      "name": "Predefined and library symbols",
      "scope": [
        "support.constant",
        "support.variable",
        "variable.language",
        "support.type"
      ],
      "settings": {
        "foreground": "#55C6F0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#9DBDD0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters variable.other",
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#D8AE68"
      }
    },
    {
      "name": "Properties and fields",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.structure.dictionary.key",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#AAB4B2"
      }
    },
    {
      "name": "Static fields and enum members",
      "scope": [
        "variable.other.constant.property",
        "variable.other.enummember",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#D8AE68"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#FFF0A6"
      }
    },
    {
      "name": "Method declarations",
      "scope": [
        "entity.name.function.method",
        "meta.method.declaration entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#F4E8A2"
      }
    },
    {
      "name": "Function and method calls",
      "scope": [
        "meta.function-call entity.name.function",
        "variable.function",
        "support.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#F4E8A2"
      }
    },
    {
      "name": "Default static methods",
      "scope": [
        "support.function.static",
        "entity.name.function.static",
        "variable.function.static"
      ],
      "settings": {
        "foreground": "#B0B0A3"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class",
        "support.type.class"
      ],
      "settings": {
        "foreground": "#FF9A84"
      }
    },
    {
      "name": "Interfaces and enums",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "support.type.interface",
        "support.type.enum"
      ],
      "settings": {
        "foreground": "#55C6F0"
      }
    },
    {
      "name": "Annotations, decorators, and metadata",
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.type.annotation",
        "punctuation.decorator",
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#6FCA83"
      }
    },
    {
      "name": "Metadata and preprocessor directives",
      "scope": [
        "keyword.control.directive",
        "keyword.other.directive",
        "meta.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#D9A4FF"
      }
    },
    {
      "name": "HTML and XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D4C88F"
      }
    },
    {
      "name": "HTML and XML attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#D8AE68"
      }
    },
    {
      "name": "Entities",
      "scope": [
        "constant.character.entity",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#D9A4FF"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#FF9A84"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#AAB4B2"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.font-name.css",
        "support.constant.media-type.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#D8AE68"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.json.comments"
      ],
      "settings": {
        "foreground": "#AAB4B2"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#E2C85B"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline"
      ],
      "settings": {
        "foreground": "#66D6C9"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#66D6C9"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#6FCA83"
      }
    },
    {
      "name": "Markup inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#6FCA83"
      }
    },
    {
      "name": "Markup deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "background": "#202020",
        "foreground": "#FF9A84"
      }
    },
    {
      "name": "Markup changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D8AE68"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#FFF5C7",
    "type": "#FF9A84",
    "class": "#FF9A84",
    "enum": "#55C6F0",
    "interface": "#55C6F0",
    "struct": "#FF9A84",
    "typeParameter": "#D8AE68",
    "parameter": "#D8AE68",
    "variable": "#9DBDD0",
    "property": "#AAB4B2",
    "enumMember": "#D8AE68",
    "event": "#D8AE68",
    "function": {
      "fontStyle": "bold",
      "foreground": "#F4E8A2"
    },
    "method": {
      "fontStyle": "bold",
      "foreground": "#F4E8A2"
    },
    "macro": "#D9A4FF",
    "keyword": {
      "fontStyle": "bold",
      "foreground": "#9EB0FF"
    },
    "modifier": {
      "fontStyle": "bold",
      "foreground": "#9EB0FF"
    },
    "comment": "#62BFC0",
    "string": "#66D6C9",
    "number": "#D9A4FF",
    "regexp": "#66D6C9",
    "operator": "#FFF5C7",
    "decorator": "#6FCA83",
    "label": "#D8AE68",
    "function.declaration": {
      "fontStyle": "bold",
      "foreground": "#FFF0A6"
    },
    "method.declaration": {
      "fontStyle": "bold",
      "foreground": "#F4E8A2"
    },
    "method.static": {
      "fontStyle": "bold",
      "foreground": "#8AD49C"
    },
    "function.static": "#B0B0A3",
    "property.static": "#D8AE68",
    "variable.readonly": "#D8AE68",
    "variable.defaultLibrary": "#55C6F0",
    "*.deprecated": {
      "fontStyle": "strikethrough",
      "foreground": "#777777"
    }
  }
}
