    "statusBar.background": "#202020",
    "statusBar.foreground": "#FFF5C7",
    "statusBar.border": "#32322F",
    "statusBar.debuggingBackground": "#2B2818",
    "statusBar.debuggingForeground": "#FFF5C7",
    "statusBar.noFolderBackground": "#202020",
    "statusBarItem.remoteBackground": "#E2C85B",
    "statusBarItem.remoteForeground": "#222222",
    "titleBar.activeBackground": "#202020",
    "titleBar.activeForeground": "#FFF5C7",
    "titleBar.inactiveBackground": "#242424",
    "titleBar.inactiveForeground": "#8F8A76",
    "titleBar.border": "#32322F",
    "menu.background": "#292929",
    "menu.foreground": "#FFF5C7",
    "menu.selectionBackground": "#484126",
    "menu.selectionForeground": "#FFF5C7",
    "menu.separatorBackground": "#3C392B",
    "menubar.selectionBackground": "#484126",
    "menubar.selectionForeground": "#FFF5C7",
    "breadcrumb.background": "#2B2818",
    "breadcrumb.foreground": "#B8AD80",
    "breadcrumb.focusForeground": "#FFF5C7",
    "breadcrumb.activeSelectionForeground": "#E2C85B",
    "minimap.background": "#2B2818",
    "minimap.selectionHighlight": "#5B5230",
    "minimap.findMatchHighlight": "#E2C85B",
    "minimap.errorHighlight": "#FF9A84",
    "minimap.warningHighlight": "#D8AE68",
    "diffEditor.insertedTextBackground": "#6FCA8322",
    "diffEditor.removedTextBackground": "#FF9A8422",
    "diffEditorGutter.insertedLineBackground": "#6FCA8318",
    "diffEditorGutter.removedLineBackground": "#FF9A8418",
    "gitDecoration.addedResourceForeground": "#6FCA83",
    "gitDecoration.modifiedResourceForeground": "#D8AE68",
    "gitDecoration.deletedResourceForeground": "#FF9A84",
    "gitDecoration.untrackedResourceForeground": "#66D6C9",
    "gitDecoration.ignoredResourceForeground": "#8F8A76",
    "debugConsole.errorForeground": "#66D6C9",
    "debugConsole.infoForeground": "#D9A4FF",
